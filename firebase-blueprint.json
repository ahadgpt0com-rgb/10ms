{
  "entities": {
    "User": {
      "title": "User",
      "description": "The isolated journal user",
      "type": "object",
      "properties": {
        "username": { "type": "string" },
        "profilePic": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["username", "createdAt"]
    },
    "JournalEntry": {
      "title": "JournalEntry",
      "description": "A single private journal entry",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["userId", "content", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profile"
    },
    "/users/{userId}/entries/{entryId}": {
      "schema": { "$ref": "#/entities/JournalEntry" },
      "description": "Private journal entries"
    }
  }
}
