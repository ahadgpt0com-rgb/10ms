rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Functions
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    
    // Users Collection (Private Journal User)
    match /users/{userId} {
      // User Validation Helper
      function isValidUser(data) {
        return data.keys().hasAll(['username', 'createdAt']) &&
               (data.keys().hasOnly(['username', 'createdAt', 'profilePic'])) &&
               data.username is string && data.username.size() > 0 && data.username.size() <= 64 &&
               data.createdAt is number &&
               (!('profilePic' in data) || (data.profilePic is string && data.profilePic.size() <= 5242880));
      }

      function isValidUserUpdate(data) {
        return isValidUser(data) && data.createdAt == existing().createdAt;
      }
      
      // Read: Only the authenticated user can read their own profile
      allow get: if isOwner(userId) && isValidId(userId);
      allow list: if isOwner(userId) && resource.data.userId == request.auth.uid; 
      
      allow create: if isOwner(userId) && isValidId(userId) && isValidUser(incoming());
      
      allow update: if isOwner(userId) && isValidId(userId) && isValidUserUpdate(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['profilePic'])
      );
      
      allow delete: if isOwner(userId) && isValidId(userId);

      // Entries Subcollection
      match /entries/{entryId} {
        function isValidJournalEntry(data) {
           return data.keys().hasAll(['userId', 'content', 'createdAt']) &&
                  data.keys().size() == 3 &&
                  data.userId is string && data.userId == request.auth.uid &&
                  data.content is string && data.content.size() > 0 && data.content.size() <= 100000 &&
                  data.createdAt is number;
        }

        allow get: if isOwner(userId) && isValidId(userId) && isValidId(entryId);
        allow list: if isOwner(userId) && isValidId(userId);
        
        allow create: if isOwner(userId) && isValidId(userId) && isValidId(entryId) && isValidJournalEntry(incoming());
        allow update: if false; 
        allow delete: if isOwner(userId) && isValidId(userId) && isValidId(entryId);
      }
    }
  }
}
