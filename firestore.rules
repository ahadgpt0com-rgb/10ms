rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function isAdmin() { 
      return isSignedIn() && (
        request.auth.token.email == "admin_boss@myspace.app" || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin")
      ); 
    }
    
    match /users/{userId} {
      function isValidUser(data) {
        return data.keys().hasAll(['username', 'role', 'createdAt']) &&
               (data.keys().hasOnly(['username', 'role', 'createdAt', 'profilePic'])) &&
               data.username is string && data.username.size() > 0 && data.username.size() <= 64 &&
               data.role is string && (data.role == "student" || data.role == "admin") &&
               data.createdAt is number &&
               (!('profilePic' in data) || (data.profilePic is string && data.profilePic.size() <= 5242880));
      }

      function isValidUserUpdate(data) {
        return isValidUser(data) && data.createdAt == existing().createdAt;
      }
      
      allow get: if isOwner(userId) && isValidId(userId);
      allow list: if isAdmin(); 
      
      allow create: if isOwner(userId) && isValidId(userId) && isValidUser(incoming());
      
      allow update: if isOwner(userId) && isValidId(userId) && isValidUserUpdate(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['profilePic', 'username']) ||
        (incoming().diff(existing()).affectedKeys().hasOnly(['profilePic', 'username', 'role']) && incoming().role == 'student') ||
        (incoming().diff(existing()).affectedKeys().hasOnly(['role']) && incoming().role == 'admin')
      );
      
      allow delete: if isOwner(userId) && isValidId(userId);
    }

    match /posts/{postId} {
      function isValidPost(data) {
         return data.keys().hasAll(['userId', 'content', 'createdAt']) &&
                (data.keys().hasOnly(['userId', 'content', 'createdAt', 'reactions', 'authorName'])) &&
                data.userId is string && data.userId == request.auth.uid &&
                data.content is string && data.content.size() > 0 && data.content.size() <= 100000 &&
                data.createdAt is number &&
                (!('authorName' in data) || (data.authorName is string && data.authorName.size() <= 64)) &&
                (!('reactions' in data) || data.reactions is map);
      }

      function isValidPostUpdate(data) {
         return data.userId == existing().userId && 
                data.content == existing().content && 
                data.createdAt == existing().createdAt &&
                (!('authorName' in data) || data.authorName == existing().authorName) &&
                (!('reactions' in data) || data.reactions is map);
      }

      allow read: if isSignedIn() && isValidId(postId);
      allow list: if isSignedIn();
      
      allow create: if isSignedIn() && isValidId(postId) && isValidPost(incoming());
      allow update: if isSignedIn() && isValidId(postId) && isValidPostUpdate(incoming()) && incoming().diff(existing()).affectedKeys().hasOnly(['reactions']); 
      allow delete: if isAdmin() && isValidId(postId);
    }
    
    match /settings/analytics {
      allow read: if isAdmin() || isSignedIn();
      allow create: if incoming().keys().hasOnly(['totalViews']) && incoming().totalViews == 1;
      allow update: if incoming().diff(existing()).affectedKeys().hasOnly(['totalViews']);
      allow write: if isAdmin();
    }
    
    match /settings/{settingId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
